# Optional: production inference on Vercel — full URL to Cloud Run POST /predict
# Example: https://thesis-predict-api-xxxxx.asia-southeast1.run.app/predict
# Leave unset (or empty) for local dev: Next.js uses Python via spawn (repo root).
PREDICT_API_URL=

# Optional: only if your Cloud Run service sets PREDICT_API_KEY (server-side only; never NEXT_PUBLIC_*)
PREDICT_API_KEY=
